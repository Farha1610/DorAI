rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isDriver() {
      return isSignedIn() && getUserData().role == 'driver';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /pickups/{pickupId} {
      allow read: if isSignedIn() && (resource.data.donorId == request.auth.uid || isAdmin() || isDriver());
      allow create: if isSignedIn() && request.resource.data.donorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.donorId == request.auth.uid || isAdmin() || isDriver());
      allow delete: if isAdmin();
    }

    match /impact/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
