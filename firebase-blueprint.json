{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["donor", "admin", "driver"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Pickup": {
      "title": "Pickup Request",
      "description": "Clothing pickup request from a donor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorId": { "type": "string" },
        "address": { "type": "string" },
        "itemsDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "completed", "cancelled"] },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "driverId": { "type": "string" },
        "weight": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["donorId", "address", "status", "createdAt"]
    },
    "Impact": {
      "title": "Impact Data",
      "description": "Environmental impact metrics for a user or global",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "weightRecycled": { "type": "number" },
        "waterSaved": { "type": "number" },
        "co2Reduced": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pickups/{pickupId}": {
      "schema": "Pickup",
      "description": "Pickup requests"
    },
    "/impact/{userId}": {
      "schema": "Impact",
      "description": "Environmental impact metrics"
    }
  }
}
